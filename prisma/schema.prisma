// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Transaction {
  id          String   @id @default(cuid())
  type        String   // 'uber' | '99' | 'combustivel' | 'gorjeta' | 'aluguel'
  amount      Float
  date        DateTime @default(now())
  description String
  weekStart   DateTime?
  weekEnd     DateTime?
}

model Report {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  createdAt DateTime @default(now())
}
